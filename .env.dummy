# DUMMY .env file for ToxTempAssistant
# This file is used for local development and testing.
# DO NOT USE THIS IN PRODUCTION.
DJANGO_DEBUG=True
USE_POSTGRES=True
SITE_URL=https://toxtempassistant.vhp4safety.nl
SECRET_KEY=
#### Foundry LLM SETTINGS, autodetect, follow the pattern AZURE_{INCREMENTAL_ENDPOINT#}_{SETTING}
AZURE_E1_ENDPOINT=https://project-1.westeurope.models.ai.azure.com
AZURE_E1_KEY=sk-...                                                                                                                                                                              
AZURE_E1_DEPLOY_GPT4O=gpt-4o-deployment          
AZURE_E1_MODEL_GPT4O=gpt-4o
AZURE_E1_TAGS_GPT4O=tier:datazone,residency:eu,provider:openai,direct-from-azure:true,version:2024-11-20,api:azure-openai,retirement-date:2026-10-01,default:true,context-window:131072,cost-input-1mtoken:2.50,cost-output-1mtoken:10.00
AZURE_E1_DEPLOY_MISTRAL=Mistral-Large-3-Euro-Zone
AZURE_E1_MODEL_MISTRAL=Mistral-Large-3                                                                                                                                                      
##                                                
AZURE_E2_ENDPOINT=https://project-2.westeurope.models.ai.azure.com                                                                                                                               
AZURE_E2_KEY=sk-...                                                                                                                                                                              
AZURE_E2_DEPLOY_LLAMA=llama3-deployment          
AZURE_E2_MODEL_LLAMA=meta-llama-3.1-70b 
####
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ALLOWED_HOSTS=toxtempassistant.vhp4safety.nl,81.169.225.178,localhost
CSRF_TRUSTED_ORIGINS=https://toxtempassistant.vhp4safety.nl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=toxtempass
# HOST change from postgres_for_django to postgres_test_for_django for testing
POSTGRES_HOST=postgres_test_for_django
POSTGRES_PORT=5432
### EMAIL (Gmail for now) ###
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
### MinIO storage ###
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
# Django / S3 client creds (minio user for the app) S3 django-storages settings
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_STORAGE_BUCKET_NAME=toxtemp
AWS_ACCESS_KEY_ID=toxtemp
AWS_SECRET_ACCESS_KEY=
### BACKUP settings ###
# BACKUP_SCHEDULE is defined in the backup-scheduler Dockerfile entrypoint.sh
BACKUP_ROOT=backups
BACKUP_RETENTION_DAYS=14
